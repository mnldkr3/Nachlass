# Anthropic API Key — erforderlich für den KI-Chat
# Hol dir einen Key auf https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Google Maps API Key für bessere Bestatter-Suche
# Ohne diesen Key wird automatisch OpenStreetMap (Nominatim) als Fallback verwendet
GOOGLE_MAPS_API_KEY=
